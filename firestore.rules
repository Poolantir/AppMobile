rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email.lower() == 'braden022@gmail.com' || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true)
      );
    }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Validation Helpers
    function isValidRestroom(data) {
      return data.keys().hasAll(['name', 'location']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.location is string && data.location.size() > 0 && data.location.size() < 100;
    }

    function isValidStall(data) {
      return data.keys().hasAll(['restroomId', 'label', 'type', 'status']) &&
             data.restroomId is string && isValidId(data.restroomId) &&
             data.label is string && data.label.size() < 50 &&
             data.type in ['stall', 'urinal'] &&
             data.status in ['online', 'offline'];
    }

    function isValidIssue(data) {
      return data.keys().hasAll(['restroomId', 'type', 'status', 'reportedAt', 'reportedBy']) &&
             data.restroomId is string && isValidId(data.restroomId) &&
             data.type in ['clogged', 'no_paper', 'broken_lock', 'unclean', 'other'] &&
             data.status in ['pending', 'resolved'] &&
             data.reportedAt == request.time &&
             data.reportedBy == request.auth.uid;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email']) &&
             data.email is string && data.email.size() < 256;
    }

    function isValidBuilding(data) {
      return data.keys().hasAll(['name', 'location']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.location is string && data.location.size() < 100;
    }

    // 1. Buildings
    match /buildings/{buildingId} {
      allow read: if true;
      allow create: if isAdmin() && isValidBuilding(incoming());
      allow update: if isAdmin() && isValidBuilding(incoming());
      allow delete: if isAdmin();
    }

    // 2. Restrooms
    match /restrooms/{restroomId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(restroomId) && isValidRestroom(incoming());
      allow update: if isAdmin() && isValidRestroom(incoming());
      allow delete: if isAdmin();
    }

    // 3. Stalls
    match /stalls/{stallId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidId(stallId) && isValidStall(incoming());
      allow delete: if isAdmin();
    }

    // 4. Issues
    match /issues/{issueId} {
      allow read: if isSignedIn();
      allow create: if isVerified() && isValidId(issueId) && isValidIssue(incoming()) && 
                    exists(/databases/$(database)/documents/restrooms/$(incoming().restroomId));
      allow update: if isAdmin() && incoming().status == 'resolved' && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['status']);
      allow delete: if isAdmin();
    }

    // 5. Users
    match /users/{userId} {
      allow read: if isOwner(userId) || (isSignedIn() && request.auth.token.email.lower() == 'braden022@gmail.com');
      allow create: if isOwner(userId) && isValidUser(incoming()) && 
                    (request.auth.token.email.lower() == 'braden022@gmail.com' || !('isAdmin' in incoming()) || incoming().isAdmin == false);
      allow update: if (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['lastSeenAt'])) ||
                    (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['isAdmin']));
    }
  }
}
